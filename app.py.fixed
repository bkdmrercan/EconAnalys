import streamlit as st
from database import init_db, register_user, verify_user
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd
import yfinance as yf
import plotly.graph_objects as go
from plotly.subplots import make_subplots
from pypfopt import expected_returns, risk_models
from pypfopt.efficient_frontier import EfficientFrontier
import re
import datetime
from io import BytesIO
import streamlit.components.v1 as components

st.set_page_config(layout="wide", page_title="EconAnalys", page_icon="")

# Veritabanını başlat
init_db()

import time

# ─── SESSION STATE ───────────────────────────────────────────────────────────
if 'logged_in' not in st.session_state:
    # Sayfa yenilemelerinde (F5) oturumun kapanmaması için URL parametresi kontrolü
    if 'user' in st.query_params:
        st.session_state.logged_in = True
        st.session_state.username = st.query_params['user']
        st.session_state.last_activity = time.time()
    else:
        st.session_state.logged_in = False
        st.session_state.last_activity = time.time()

        if 'username' not in st.session_state:
            st.session_state.username = ""

# Oturum Zaman Aşımı Kontrolü (Örn: 1 Saat / 3600 saniye)
            if st.session_state.get('logged_in', False):
                if time.time() - st.session_state.get('last_activity', time.time()) > 3600:
                    st.session_state.logged_in = False
                    st.session_state.username = ""
                    st.query_params.clear()
                    st.warning("Oturumunuz uzun süre işlem yapılmadığı için zaman aşımına uğradı.")
                    st.rerun()
                else:
                    st.session_state.last_activity = time.time()

                    def do_logout():
                        st.session_state.logged_in = False
                        st.session_state.username = ""
                        st.query_params.clear()

                        css = """
                        <style>
                        @import url('https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;1,14..32,400&display=swap');

                        /* ═══════════════════════════════════════════
                        RENK SİSTEMİ — AÇIK MOD
                        ═══════════════════════════════════════════ */
                        :root {
                        --accent: #2563EB;
                        --accent-light: #3b82f6;
                        --accent-dim: rgba(37,99,235,0.08);
                        --neon-accent: #2563EB;

                        /* Arka planlar */
                        --bg-body: #f0f4fa;
                        --bg-card: #ffffff;
                        --bg-card2: #f8fafd;
                        --bg-input: #f1f5fb;

                        /* Kenarlık & metin */
                        --border: rgba(37,99,235,0.12);
                        --text-primary: #0f172a;
                        --text-muted: #64748b;
                        --text-placeholder: #94a3b8;

                        /* Gölgeler */
                        --shadow-sm: 0 2px 8px rgba(37,99,235,0.06);
                        --shadow-card: 0 8px 40px rgba(37,99,235,0.10), 0 2px 8px rgba(0,0,0,0.04);
                        --shadow-btn: 0 4px 14px rgba(37,99,235,0.30);
                        --shadow-btn-h: 0 6px 20px rgba(37,99,235,0.45);

                        /* Auth arka plan gradyanı */
                        --auth-gradient: linear-gradient(135deg, #e8f0fe 0%, #f0f4fa 40%, #e0eaff 100%);
                        }

                        /* ═══════════════════════════════════════════
                        RENK SİSTEMİ — KOYU MOD
                        ═══════════════════════════════════════════ */
                        [data-theme="dark"] {
                        --accent: #3b82f6;
                        --accent-light: #60a5fa;
                        --accent-dim: rgba(59,130,246,0.12);
                        --neon-accent: #60a5fa;

                        --bg-body: #0b0f1a;
                        --bg-card: #111827;
                        --bg-card2: #161d2e;
                        --bg-input: #1e293b;

                        --border: rgba(59,130,246,0.15);
                        --text-primary: #f1f5f9;
                        --text-muted: #94a3b8;
                        --text-placeholder: #475569;

                        --shadow-sm: 0 2px 8px rgba(0,0,0,0.30);
                        --shadow-card: 0 8px 40px rgba(0,0,0,0.50), 0 2px 8px rgba(59,130,246,0.08);
                        --shadow-btn: 0 4px 14px rgba(59,130,246,0.35);
                        --shadow-btn-h: 0 6px 20px rgba(59,130,246,0.55);

                        --auth-gradient: linear-gradient(135deg, #0b0f1a 0%, #0f172a 50%, #0d1529 100%);
                        }

                        /* Streamlit koyu mod auto-detect */
                        [data-testid="stAppViewContainer"][data-theme="dark"],
                        .dark [data-testid="stAppViewContainer"] {
                        --accent: #3b82f6;
                        --neon-accent: #60a5fa;
                        --bg-body: #0b0f1a;
                        --bg-card: #111827;
                        --bg-input: #1e293b;
                        --border: rgba(59,130,246,0.15);
                        --text-primary: #f1f5f9;
                        --text-muted: #94a3b8;
                        --shadow-card: 0 8px 40px rgba(0,0,0,0.50);
                        --shadow-btn: 0 4px 14px rgba(59,130,246,0.35);
                        --auth-gradient: linear-gradient(135deg, #0b0f1a 0%, #0f172a 50%, #0d1529 100%);
                        }

                        /* ═══════════════════════════════════════════
                        GENEL ALTYAPI
                        ═══════════════════════════════════════════ */
                        [data-testid="stSidebar"] { display: none !important; }

                        *, *::before, *::after { box-sizing: border-box; }

                        body, .stApp {
                        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif !important;
                        background-color: var(--background-color);
                        }

                        /* ═══════════════════════════════════════════
                        SEKMELER (TABS) — EMOJİSİZ ve MODA GÖRE
                        ═══════════════════════════════════════════ */
                        .stTabs [data-baseweb="tab-list"] {
                        gap: 0;
                        border-bottom: 1.5px solid var(--border-color);
                        justify-content: center;
                        margin-bottom: 28px;
                        background: transparent !important;
                        }
                        .stTabs [data-baseweb="tab"] {
                        font-family: 'Inter', sans-serif !important;
                        font-size: 0.78rem;
                        font-weight: 700;
                        letter-spacing: 0.8px;
                        text-transform: uppercase;
                        color: var(--text-color);
                        opacity: 0.55;
                        padding: 11px 22px;
                        background: transparent !important;
                        border: none;
                        border-bottom: 3px solid transparent;
                        border-radius: 0;
                        transition: opacity 0.2s, border-color 0.2s;
                        white-space: nowrap;
                        }
                        .stTabs [data-baseweb="tab"]:hover {
                        opacity: 0.85 !important;
                        }
                        .stTabs [aria-selected="true"] {
                        color: var(--accent) !important;
                        opacity: 1 !important;
                        background: transparent !important;
                        border-bottom: 3px solid var(--accent) !important;
                        }

                        /* Açık Modda tabs */
                        @media (prefers-color-scheme: light) {
                        .stTabs [aria-selected="true"] {
                        color: #1d4ed8 !important;
                        border-bottom-color: #1d4ed8 !important;
                        }
                        }
                        /* Koyu Modda tabs */
                        @media (prefers-color-scheme: dark) {
                        .stTabs [aria-selected="true"] {
                        color: #60a5fa !important;
                        border-bottom-color: #60a5fa !important;
                        }
                        }

                        /* ═══════════════════════════════════════════
                        KONTEYNER KARTLARI
                        ═══════════════════════════════════════════ */
                        div[data-testid="stVerticalBlockBorderWrapper"] {
                        background-color: var(--secondary-background-color) !important;
                        border-radius: 12px !important;
                        border: 1px solid var(--border-color) !important;
                        padding: 24px !important;
                        margin-bottom: 0 !important;
                        transition: box-shadow 0.2s;
                        }

                        /* Açık mod kart gölgesi */
                        @media (prefers-color-scheme: light) {
                        div[data-testid="stVerticalBlockBorderWrapper"] {
                        box-shadow: 0 2px 16px rgba(37,99,235,0.05) !important;
                        }
                        }
                        /* Koyu mod kart gölgesi */
                        @media (prefers-color-scheme: dark) {
                        div[data-testid="stVerticalBlockBorderWrapper"] {
                        box-shadow: 0 4px 24px rgba(0,0,0,0.35) !important;
                        }
                        }

                        /* ═══════════════════════════════════════════
                        TABLO
                        ═══════════════════════════════════════════ */
                        .custom-table {
                        width: 100%; border-collapse: collapse;
                        font-family: 'Inter', sans-serif; font-size: 0.9rem; margin-top: 5px;
                        }
                        .custom-table th {
                        text-align: right; padding: 10px;
                        color: var(--text-color); opacity: 0.7;
                        font-weight: 600; border-bottom: 1px solid var(--border-color); font-size: 0.8rem;
                        }
                        .custom-table th:first-child { text-align: left; }
                        .custom-table td {
                        padding: 12px 10px; border-bottom: 1px solid var(--border-color);
                        text-align: right; color: var(--text-color);
                        }
                        .custom-table td:first-child { text-align: left; font-weight: 500; }
                        .custom-table tr.active-row { background-color: rgba(37,99,235,0.08); border-radius: 6px; }
                        .active-row td { border-bottom: none; color: #2563eb; }
                        .positive-change { color: #10b981 !important; font-weight: 600; }
                        .negative-change { color: #ef4444 !important; font-weight: 600; }

                        /* ═══════════════════════════════════════════
                        METRİK, BAŞLIK, NOTLAR
                        ═══════════════════════════════════════════ */
                        .tv-metric-box {
                        text-align: center; padding: 15px 10px; border-radius: 8px;
                        background: var(--background-color);
                        border: 1px solid var(--border-color);
                        box-shadow: 0 1px 4px rgba(0,0,0,0.04); margin-bottom: 5px;
                        }
                        .tv-metric-title {
                        font-size: 0.78rem; color: var(--text-color) !important;
                        text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px;
                        margin-bottom: 6px; line-height: 1.1; opacity: 0.65;
                        }
                        .tv-metric-value { font-size: 1.6rem; font-weight: 800; color: var(--neon-accent) !important; }
                        .tv-title {
                        background-color: var(--secondary-background-color) !important;
                        color: var(--text-color) !important;
                        padding: 9px 15px; border-radius: 6px;
                        font-family: 'Inter', sans-serif !important;
                        border: 1px solid var(--border-color);
                        font-size: 0.8rem; font-weight: 800;
                        margin-bottom: 15px; text-align: center;
                        text-transform: uppercase; letter-spacing: 1px;
                        }
                        .tv-note-box { padding: 12px; border-left: 4px solid #F23645; background: rgba(242,54,69,0.05); border-radius: 4px; font-size: 0.95rem; margin-bottom: 15px; }
                        .tv-note-box-green { padding: 12px; border-left: 4px solid #089981; background: rgba(8,153,129,0.05); border-radius: 4px; font-size: 0.95rem; margin-bottom: 15px; }
                        .econ-footer { text-align: center; font-size: 0.82rem; color: var(--text-color); opacity: 0.45; padding: 15px 0; margin-top: 30px; letter-spacing: 0.5px; }

                        /* ═══════════════════════════════════════════
                        GİRİŞ / AUTH EKRANI — AÇIK MOD
                        ═══════════════════════════════════════════ */
                        .auth-page-bg {
                        position: fixed; inset: 0; z-index: -1;
                        background: linear-gradient(135deg, #e8f0fe 0%, #f0f4fa 50%, #dde8ff 100%);
                        pointer-events: none;
                        }
                        .auth-page-bg::before {
                        content: '';
                        position: absolute; inset: 0;
                        background:
                        radial-gradient(ellipse 700px 500px at 20% 20%, rgba(37,99,235,0.07) 0%, transparent 70%),
                        radial-gradient(ellipse 600px 400px at 80% 80%, rgba(14,165,233,0.06) 0%, transparent 70%);
                        }
                        .auth-outer {
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        min-height: 82vh;
                        padding: 24px 12px;
                        }
                        .auth-card {
                        background: rgba(255,255,255,0.82);
                        backdrop-filter: blur(20px) saturate(1.4);
                        -webkit-backdrop-filter: blur(20px) saturate(1.4);
                        border: 1px solid rgba(255,255,255,0.9);
                        border-radius: 20px;
                        box-shadow:
                        0 8px 48px rgba(37,99,235,0.10),
                        0 2px 12px rgba(37,99,235,0.06),
                        inset 0 1px 0 rgba(255,255,255,0.9);
                        padding: 44px 48px 40px;
                        width: 100%; max-width: 430px;
                        margin: 0 auto;
                        animation: fadeSlideUp 0.5s cubic-bezier(.22,1,.36,1) both;
                        }
                        @keyframes fadeSlideUp {
                        from { opacity: 0; transform: translateY(22px); }
                        to { opacity: 1; transform: translateY(0); }
                        }
                        .auth-logo-wrap {
                        text-align: center;
                        margin-bottom: 4px;
                        }
                        .auth-logo-icon {
                        display: inline-block;
                        width: 52px; height: 52px;
                        background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
                        border-radius: 14px;
                        box-shadow: 0 4px 16px rgba(37,99,235,0.30);
                        color: #fff;
                        font-size: 1.5rem;
                        line-height: 52px;
                        text-align: center;
                        margin-bottom: 14px;
                        animation: iconPop 0.6s 0.2s cubic-bezier(.34,1.56,.64,1) both;
                        }
                        @keyframes iconPop {
                        from { transform: scale(0.6); opacity: 0; }
                        to { transform: scale(1); opacity: 1; }
                        }
                        .auth-title {
                        font-family: 'Inter', sans-serif;
                        font-size: 1.9rem; font-weight: 800;
                        letter-spacing: -0.8px;
                        color: #0f172a;
                        margin-bottom: 4px;
                        }
                        .auth-title span { color: #2563eb; }
                        .auth-badge {
                        display: inline-block;
                        background: linear-gradient(90deg, rgba(37,99,235,0.10) 0%, rgba(14,165,233,0.10) 100%);
                        color: #2563eb;
                        font-family: 'Inter', sans-serif;
                        font-size: 0.72rem; font-weight: 700;
                        letter-spacing: 0.8px; text-transform: uppercase;
                        padding: 4px 12px;
                        border-radius: 20px;
                        border: 1px solid rgba(37,99,235,0.18);
                        margin-bottom: 28px;
                        margin-top: 6px;
                        }
                        .auth-section-label {
                        font-family: 'Inter', sans-serif;
                        font-size: 0.72rem; font-weight: 700;
                        letter-spacing: 0.6px; text-transform: uppercase;
                        color: #64748b;
                        margin-bottom: 20px;
                        margin-top: 8px;
                        padding-bottom: 10px;
                        border-bottom: 1px solid rgba(37,99,235,0.10);
                        }
                        .auth-footer {
                        text-align: center;
                        font-size: 0.74rem;
                        color: #94a3b8;
                        margin-top: 20px;
                        letter-spacing: 0.3px;
                        }

                        /* ─── Streamlit input/button overrides (auth bölgesi) ─── */
                        .auth-form-zone [data-testid="stTextInput"] label {
                        font-size: 0.78rem !important;
                        font-weight: 700 !important;
                        letter-spacing: 0.4px !important;
                        text-transform: uppercase !important;
                        color: #475569 !important;
                        margin-bottom: 4px !important;
                        }
                        .auth-form-zone [data-testid="stTextInput"] input {
                        border-radius: 10px !important;
                        border: 1.5px solid rgba(37,99,235,0.15) !important;
                        background: #f8faff !important;
                        padding: 10px 14px !important;
                        font-size: 0.92rem !important;
                        transition: border-color 0.2s, box-shadow 0.2s !important;
                        color: #0f172a !important;
                        }
                        .auth-form-zone [data-testid="stTextInput"] input:focus {
                        border-color: #2563eb !important;
                        box-shadow: 0 0 0 3px rgba(37,99,235,0.12) !important;
                        background: #fff !important;
                        }
                        .auth-form-zone button[kind="primary"],
                        .auth-form-zone button[kind="secondary"] {
                        border-radius: 10px !important;
                        font-weight: 700 !important;
                        font-size: 0.88rem !important;
                        letter-spacing: 0.3px !important;
                        transition: all 0.2s !important;
                        }

                        /* ═══════════════════════════════════════════
                        GİRİŞ / AUTH EKRANI — KOYU MOD
                        ═══════════════════════════════════════════ */
                        @media (prefers-color-scheme: dark) {
                        .auth-page-bg {
                        background: linear-gradient(135deg, #070c18 0%, #0b1020 50%, #080f1e 100%) !important;
                        }
                        .auth-page-bg::before {
                        background:
                        radial-gradient(ellipse 700px 500px at 20% 20%, rgba(59,130,246,0.06) 0%, transparent 70%),
                        radial-gradient(ellipse 600px 400px at 80% 80%, rgba(14,165,233,0.05) 0%, transparent 70%);
                        }
                        .auth-card {
                        background: rgba(17,24,39,0.92) !important;
                        border-color: rgba(59,130,246,0.14) !important;
                        box-shadow:
                        0 8px 48px rgba(0,0,0,0.55),
                        0 2px 12px rgba(59,130,246,0.08),
                        inset 0 1px 0 rgba(255,255,255,0.04) !important;
                        }
                        .auth-title { color: #f1f5f9 !important; }
                        .auth-title span { color: #60a5fa !important; }
                        .auth-badge {
                        background: linear-gradient(90deg, rgba(59,130,246,0.12) 0%, rgba(14,165,233,0.10) 100%) !important;
                        color: #60a5fa !important;
                        border-color: rgba(59,130,246,0.22) !important;
                        }
                        .auth-section-label { color: #475569 !important; border-bottom-color: rgba(59,130,246,0.10) !important; }
                        .auth-footer { color: #334155 !important; }

                        .auth-form-zone [data-testid="stTextInput"] label { color: #64748b !important; }
                        .auth-form-zone [data-testid="stTextInput"] input {
                        background: #1e293b !important;
                        border-color: rgba(59,130,246,0.18) !important;
                        color: #f1f5f9 !important;
                        }
                        .auth-form-zone [data-testid="stTextInput"] input:focus {
                        border-color: #3b82f6 !important;
                        box-shadow: 0 0 0 3px rgba(59,130,246,0.15) !important;
                        background: #1e293b !important;
                        }
                        }
                        </style>
                        """
                        st.markdown(css, unsafe_allow_html=True)

# ─── AUTH GUARD ──────────────────────────────────────────────────────────────
                        if not st.session_state.logged_in:
    # Arka plan degrade katmanı
                            st.markdown("<div class='auth-page-bg'></div>", unsafe_allow_html=True)

                            _, auth_col, _ = st.columns([1, 1.5, 1])
                            with auth_col:
        # Logo & Başlık
                                st.markdown("""
                                <div style="text-align:center; margin-bottom: 0px;">
                                <div class="auth-logo-icon">&#9670;</div>
                                <div class="auth-title"><span>Econ</span>Analys</div>
                                <div class="auth-badge">Kocaeli Üniversitesi &middot; İktisat Analiz Platformu</div>
                                </div>
                                """, unsafe_allow_html=True)

        # Tabs
                                auth_tab_login, auth_tab_register = st.tabs(["Giriş Yap", "Kayıt Ol"])

                                st.markdown("<div class='auth-form-zone'>", unsafe_allow_html=True)

                                with auth_tab_login:
                                    st.markdown("<div class='auth-section-label'>Hesabınıza giriş yapın</div>", unsafe_allow_html=True)
                                    login_user = st.text_input("Kullanıcı Adı", placeholder="kullanici_adi", key="login_user")
                                    login_pass = st.text_input("Şifre", type="password", placeholder="••••••", key="login_pass")
                                    st.markdown("<div style='height:8px'></div>", unsafe_allow_html=True)
                                    if st.button("Giriş Yap", use_container_width=True, key="btn_login", type="primary"):
                                        if login_user and login_pass:
                                            ok, msg = verify_user(login_user, login_pass)
                                            if ok:
                                                st.session_state.logged_in = True
                                                st.session_state.username = login_user.strip().lower()
                                                st.query_params['user'] = login_user.strip().lower()
                                                st.rerun()
                                            else:
                                                st.error(msg)
                                            else:
                                                st.warning("Lütfen kullanıcı adı ve şifrenizi girin.")
                                                if st.button("Şifremi Unuttum?", use_container_width=True, key="btn_forgot_pw"):
                                                    st.info("Şifrenizi sıfırlamak için lütfen sistem yöneticisi ile iletişime geçin.")

                                                    with auth_tab_register:
                                                        st.markdown("<div class='auth-section-label'>Yeni hesap oluşturun</div>", unsafe_allow_html=True)
                                                        reg_user = st.text_input("Kullanıcı Adı", placeholder="kullanici_adi", key="reg_user")
                                                        reg_pass = st.text_input("Şifre", type="password", placeholder="En az 6 karakter", key="reg_pass")
                                                        reg_pass2 = st.text_input("Şifreyi Onayla", type="password", placeholder="••••••", key="reg_pass2")
                                                        st.markdown("<div style='height:8px'></div>", unsafe_allow_html=True)
                                                        if st.button("Kayıt Ol", use_container_width=True, key="btn_register", type="primary"):
                                                            if not reg_user or not reg_pass or not reg_pass2:
                                                                st.warning("Tüm alanları doldurun.")
                                                            elif reg_pass != reg_pass2:
                                                                st.error("Şifreler eşleşmiyor.")
                                                            else:
                                                                ok, msg = register_user(reg_user, reg_pass)
                                                                if ok:
                                                                    st.success(msg)
                                                                else:
                                                                    st.error(msg)

                                                                    st.markdown("</div>", unsafe_allow_html=True)
                                                                    st.markdown("<div class='auth-footer'>&copy; 2025 EconAnalys &middot; designed by Quartet</div>", unsafe_allow_html=True)
                                                                    st.stop()  # Giriş yoksa burada dur
# ─────────────────────────────────────────────────────────────────────────────

                                                                    try: c_theme = st.get_option('theme.base')
                                                                except: c_theme = "light"
                                                                    dyn_template = "plotly_dark" if c_theme == "dark" else "plotly_white"

                                                                    tv_layout = {
                                                                    "template": dyn_template, "paper_bgcolor": "rgba(0,0,0,0)", "plot_bgcolor": "rgba(0,0,0,0)",
                                                                    "font": {"family": "'Inter', sans-serif", "size": 14},
                                                                    "xaxis": {"showgrid": True, "gridcolor": "rgba(128,128,128,0.2)", "gridwidth": 1, "zeroline": False},
                                                                    "yaxis": {"showgrid": True, "gridcolor": "rgba(128,128,128,0.2)", "gridwidth": 1, "zeroline": False},
                                                                    "margin": {"l": 40, "r": 15, "t": 40, "b": 40}
                                                                    }
                                                                    color_blue, color_orange, color_green, color_red = "#2563EB", "#F59E0B", "#10B981", "#EF4444"

                                                                    def clean_formula(f):
                                                                        if not f: return ""
                                                                        f = f.replace('^', '**')
                                                                        f = re.sub(r'(?<![a-zA-Z])[pPqQsS](?![a-zA-Z])', 'x', f)
                                                                        return re.sub(r'(\d+)([a-zA-Z])', r'\1*\2', f)

                                                                        def metric_html(title, value, override_color=None):
                                                                            return f"""<div class="tv-metric-box"><div class="tv-metric-title">{title}</div><div class="tv-metric-value" style="color: {override_color or 'var(--neon-accent)'} !important;">{value}</div></div>"""

                                                                            def slice_desc(color, title, text):
                                                                                return f"""
                                                                                <div style="margin-bottom: 12px; display: flex; align-items: flex-start;">
                                                                                <div style="width: 12px; height: 12px; border-radius: 50%; background-color: {color}; margin-top: 4px; margin-right: 10px; flex-shrink: 0;"></div>
                                                                                <div>
                                                                                <span style="font-weight: 700; font-size: 0.95rem;">{title}</span><br>
                                                                                <span style="font-size: 0.85rem; opacity: 0.8; line-height: 1.35; display: block; margin-top: 2px;">{text}</span>
                                                                                </div>
                                                                                </div>
                                                                                """

                                                                                def init_macro():
                                                                                    defaults = {
                                                                                    'm_Co': 0.0, 'm_I': 0.0, 'm_G': 0.0, 'm_X': 0.0, 'm_Mo': 0.0, 
                                                                                    'm_Yf': 0.0, 'm_c': 0.0, 'm_s': 0.0, 'm_t': 0.0, 'm_m': 0.0,
                                                                                    'm_Rev': 0.0, 'm_Exp': 0.0
                                                                                    }
                                                                                    for k, v in defaults.items():
                                                                                        if k not in st.session_state: st.session_state[k] = v

                                                                                        init_macro()

                                                                                        def update_c(): st.session_state.m_s = max(0.0, round(float(1.0 - st.session_state.m_c), 4))
                                                                                        def update_s(): st.session_state.m_c = max(0.0, round(float(1.0 - st.session_state.m_s), 4))

                                                                                        def set_scenario(co, c, i, g, t, x, mo, m):
                                                                                            st.session_state['m_Co'], st.session_state['m_c'], st.session_state['m_I'], st.session_state['m_G'] = float(co), float(c), float(i), float(g)
                                                                                            st.session_state['m_t'], st.session_state['m_X'], st.session_state['m_Mo'], st.session_state['m_m'] = float(t), float(x), float(mo), float(m)
                                                                                            st.session_state['m_s'] = round(float(1.0 - st.session_state['m_c']), 4)

                                                                                            def param_input(label, key):
                                                                                                st.markdown(f"<div style='font-size: 0.85rem; font-weight: 600; opacity: 0.8; margin-top: 8px; margin-bottom: 2px;'>{label}</div>", unsafe_allow_html=True)
                                                                                                st.number_input("dummy_auto", min_value=0.0, key=key, format="%.2f", label_visibility="collapsed")

                                                                                                c_h1, c_h2, c_h3 = st.columns([1, 4, 2])
                                                                                                with c_h2: 
                                                                                                    st.markdown("<h2 style='text-align: center; font-family: \"Inter\", sans-serif; font-weight: 800; margin-bottom: 20px; letter-spacing: -0.5px;'><span style='color: var(--neon-accent); font-size: 2rem;'></span> EconAnalys</h2>", unsafe_allow_html=True)
                                                                                                    with c_h3:
                                                                                                        st.markdown("<div style='margin-top: 15px;'></div>", unsafe_allow_html=True)
                                                                                                        btn_col1, btn_col2 = st.columns(2)
                                                                                                        with btn_col1:
                                                                                                            components.html("""
                                                                                                            <script>
                                                                                                            function triggerPrint() { window.parent.print(); }
                                                                                                            </script>
                                                                                                            <button onclick="triggerPrint()" style="background-color: transparent; border: 1.5px solid #111827; color: #111827; border-radius: 6px; padding: 8px 12px; width: 100%; font-family: 'Inter', sans-serif; font-weight: 600; font-size: 0.85rem; cursor: pointer; transition: 0.2s;">
                                                                                                            PDF
                                                                                                            </button>
                                                                                                            """, height=45)
                                                                                                            with btn_col2:
                                                                                                                st.markdown(f"<div style='font-size:0.75rem;opacity:0.65;text-align:center;margin-top:4px;'> {st.session_state.username}</div>", unsafe_allow_html=True)
                                                                                                                st.button("Çıkış", on_click=do_logout, use_container_width=True, key="btn_logout")

                                                                                                                tab_gosterge, tab_makro, tab_mikro, tab_islm, tab_borsa, tab_portfoy, tab_enflasyon = st.tabs([
                                                                                                                "GÖSTERGE PANELİ", "MAKRO SİMÜLASYON", "MİKRO İKTİSAT", "IS-LM ANALİZİ", "BORSA TAKİP", "PORTFÖY", "ENFLASYON"
                                                                                                                ])

# --------------------------------
# TAB 0: GÖSTERGE PANELİ (TASARIM UYGULAMASI)
# --------------------------------
                                                                                                                with tab_gosterge:
    # Beyaz Gölgeli Ana Kart (Container)
                                                                                                                    with st.container(border=True):
    
    # İçeriği sütunlara böl
                                                                                                                        col1, col2, col3 = st.columns([1.5, 1, 0.8])
    
    # --- Sol Sütun: TR Büyüme (GSYH) Tahmini (Area Chart) ---
                                                                                                                        with col1:
                                                                                                                            st.markdown("<h4 style='color: var(--text-color); font-size: 1.1rem; margin-bottom: 0px;'>Büyüme (GSYH) Tahmini</h4>", unsafe_allow_html=True)
    
    # Yer tutucu veriler
                                                                                                                            x_data = ['Eki 25', 'Kas 25', 'Ara 25', 'Oca 26', 'Mar 26', 'Nis 26']
                                                                                                                            y_data = [1.7, 1.45, 2.3, 2.0, 2.3, 1.9, 1.3, 2.1, 2.8, 2.8, 3.4]
